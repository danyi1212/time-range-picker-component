{
  "name": "@danyi/time-range-picker",
  "version": "0.1.0",
  "private": false,
  "files": [
    "dist",
    "registry",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./time-range-picker": {
      "types": "./dist/time-range-picker.d.ts",
      "import": "./dist/time-range-picker.js"
    },
