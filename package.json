{
  "name": "time-range-picker-component",
  "private": true,
  "scripts": {
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter demo test:e2e",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "oxlint": "^0.16.10",
    "oxfmt": "^0.40.0",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["oxlint --fix", "oxfmt"],
    "*.{css,json,yaml}": ["oxfmt"]
  },
  "packageManager": "pnpm@10.11.0"
}
