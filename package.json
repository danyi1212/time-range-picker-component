{
  "name": "time-range-picker-component",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "build": "pnpm build:packages && pnpm --filter demo build",
    "build:packages": "pnpm --filter @danyi1212/time-range-picker build",
    "build:registry": "pnpm --filter @danyi1212/time-range-picker build:registry",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter demo test:e2e",
    "test:e2e:stress": "CI=1 pnpm --filter demo exec playwright test e2e/time-range-picker.spec.ts --grep 'theme control cycles through system, dark, and light|blur commits|paused live ranges' --repeat-each=10 --workers=4",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && pnpm build:registry && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@oxfmt/binding-darwin-arm64": "0.40.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^0.16.12",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{css,json,yaml}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "overrides": {
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4"
    }
  }
}
